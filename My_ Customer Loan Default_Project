        "query = \"\"\"\n",
        "SELECT\n",
        "CASE\n",
        "WHEN debt_to_income_ratio < 10 THEN 'Low DTI'\n",
        "WHEN debt_to_income_ratio BETWEEN 10 AND 20 THEN 'Medium DTI'\n",
        "ELSE 'High DTI'\n",
        "END AS debt_to_income_ratio_category,\n",
        "AVG(loan_default) * 100 AS default_rate\n",
        "FROM df\n",
        "GROUP BY debt_to_income_ratio_category\n",
        "\"\"\"\n",
        "pysqldf(query)"
      ]
    },
